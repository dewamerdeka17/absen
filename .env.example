# Neon Postgres connection string from Vercel Marketplace
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-at-least-32-random-characters

# Used by the Android bundle. Leave empty for same-origin web deployment.
VITE_API_URL=https://your-project.vercel.app

# Optional for npm run seed:admin
ORG_NAME=Nama Perusahaan
ORG_SLUG=nama-perusahaan
OWNER_NAME=Nama Owner
OWNER_EMAIL=owner@perusahaan.com
OWNER_PASSWORD=PasswordMinimal8
