# Neon Postgres connection string from Vercel Marketplace
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-at-least-32-random-characters

# Used by the Android bundle. Leave empty for same-origin web deployment.
VITE_API_URL=https://your-project.vercel.app

# Google OAuth login. Add this redirect URI in Google Cloud:
# https://your-project.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://your-project.vercel.app/api/auth/google/callback
APP_ORIGIN=https://your-project.vercel.app
